#!/usr/bin/env bash
set -euo pipefail

MAX_FILE_MB="${MAX_FILE_MB:-20}"
MAX_BYTES=$((MAX_FILE_MB * 1000 * 1000))

staged_files="$(git diff --cached --name-only --diff-filter=AM)"
[ -z "${staged_files}" ] && exit 0

too_large=()
while IFS= read -r file; do
    [ -f "${file}" ] || continue
    size="$(wc -c <"${file}")"
    if [ "${size}" -gt "${MAX_BYTES}" ]; then
        too_large+=("${file}:${size}")
    fi
done <<< "${staged_files}"

if [ "${#too_large[@]}" -gt 0 ]; then
    echo "pre-commit: blocked oversized staged files (limit ${MAX_FILE_MB}MB):"
    for entry in "${too_large[@]}"; do
        file="${entry%%:*}"
        bytes="${entry##*:}"
        echo "  ${file} (${bytes} bytes)"
    done
    echo "If intentional, store heavy artifacts outside git or use Git LFS."
    exit 1
fi

